APP_ENV=dev
PROJECT_APPS=ceeb_web,alumnat,competicions_trampoli,marbella_informes,designacions
DJANGO_SECRET_KEY=dev-only-change-me
DEBUG=1

ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok-free.app,.ngrok.app,.ngrok-free.dev,.ngrok.dev
CSRF_TRUSTED_ORIGINS=https://*.ngrok-free.app,https://*.ngrok.app,https://*.ngrok-free.dev,https://*.ngrok.dev
USE_X_FORWARDED_PROTO=1
DATA_UPLOAD_MAX_NUMBER_FILES=500
DATA_UPLOAD_MAX_MEMORY_SIZE=157286400
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
JUDGE_VIDEO_FFPROBE_BIN=ffprobe
JUDGE_VIDEO_FFPROBE_TIMEOUT_SECONDS=15

POSTGRES_DB=ceeb_db
POSTGRES_USER=ceeb_user
POSTGRES_PASSWORD=ceeb_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

MEDIA_URL=/media/
MEDIA_ROOT=/data/media
